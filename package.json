{
  "name": "chaos-pizza-api",
  "version": "1.0.0",
  "description": "API de livraison de pizza instable",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "load-test": "artillery run loadtest.yml",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "jest": "^30.2.0",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "artillery": "^2.0.0-31",
    "supertest": "^7.2.2"
  }
}
